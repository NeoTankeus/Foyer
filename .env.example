# ===========================================
# Base de données
# ===========================================
# SQLite (développement local)
DATABASE_URL="file:./dev.db"

# PostgreSQL (production - remplacer par votre URL)
# DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# ===========================================
# NextAuth
# ===========================================
# Générer avec: openssl rand -base64 32
AUTH_SECRET="votre-secret-ultra-securise-genere-avec-openssl"

# URL de base de l'application
NEXTAUTH_URL="http://localhost:3000"

# ===========================================
# Application
# ===========================================
# Devise par défaut (EUR, USD, etc.)
DEFAULT_CURRENCY="EUR"

# Format de date (fr-FR, en-US, etc.)
DEFAULT_LOCALE="fr-FR"

# ===========================================
# Production (Vercel)
# ===========================================
# VERCEL_URL est automatiquement défini par Vercel
# AUTH_URL est automatiquement défini par Vercel
